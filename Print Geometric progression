#include <iostream>
using namespace std;

int main() {
    int a, r, n;

    cout << "Enter first term (a): ";
    cin >> a;

    cout << "Enter common ratio (r): ";
    cin >> r;

    cout << "Enter number of terms (n): ";
    cin >> n;

    cout << "Geometric Progression: ";

    int term = a;
    for(int i = 1; i <= n; i++) {
        cout << term << " ";
        term = term * r;
    }

    return 0;
}
