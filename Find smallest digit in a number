#include <iostream>
using namespace std;

int main() {
    int num, digit, smallest = 9;

    cout << "Enter a number: ";
    cin >> num;

    while(num > 0) {
        digit = num % 10;   // get last digit

        if(digit < smallest) {
            smallest = digit;
        }

        num = num / 10;     // remove last digit
    }

    cout << "Smallest digit = " << smallest;

    return 0;
}
