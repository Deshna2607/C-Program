#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Enter number of rows (half diamond): ";
    cin >> n;

    // Upper part (pyramid)
    for(int i = 1; i <= n; i++) {
        // Spaces
        for(int j = 1; j <= n - i; j++) {
            cout << " ";
        }
        // Stars
        for(int k = 1; k <= (2*i - 1); k++) {
            cout << "*";
        }
        cout << endl;
    }

    // Lower part (inverted pyramid)
    for(int i = n - 1; i >= 1; i--) {
        // Spaces
        for(int j = 1; j <= n - i; j++) {
            cout << " ";
        }
        // Stars
        for(int k = 1; k <= (2*i - 1); k++) {
            cout << "*";
        }
        cout << endl;
    }

    return 0;
}
