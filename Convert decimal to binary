#include <iostream>
using namespace std;

int main() {
    int num, binary[32], i = 0;

    cout << "Enter a decimal number: ";
    cin >> num;

    int n = num; // store original number

    // Conversion process
    while (n > 0) {
        binary[i] = n % 2;
        n = n / 2;
        i++;
    }

    cout << "Binary equivalent of " << num << " is: ";

    // Print in reverse order
    for (int j = i - 1; j >= 0; j--) {
        cout << binary[j];
    }

    return 0;
}
