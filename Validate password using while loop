#include <iostream>
#include <string>
using namespace std;

int main() {
    string password;
    string correctPassword = "12345";

    cout << "Enter password: ";
    cin >> password;

    // Keep asking until correct password is entered
    while(password != correctPassword) {
        cout << "Incorrect password! Try again: ";
        cin >> password;
    }

    cout << "Access Granted!";

    return 0;
}
