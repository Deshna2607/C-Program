#include <iostream>
#include <string>
using namespace std;

int main() {
    string password;
    string correctPassword = "admin123";
    int attempts = 0;

    while(attempts < 3) {
        cout << "Enter password: ";
        cin >> password;

        if(password == correctPassword) {
            cout << "Login Successful!";
            return 0;
        } else {
            attempts++;
            cout << "Incorrect password! Attempts left: " << 3 - attempts << endl;
        }
    }

    cout << "Account locked! Too many failed attempts.";

    return 0;
}
