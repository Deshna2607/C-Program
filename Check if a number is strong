#include <iostream>
using namespace std;

// Function to find factorial
int factorial(int n) {
    int fact = 1;
    for (int i = 1; i <= n; i++) {
        fact *= i;
    }
    return fact;
}

int main() {
    int num, originalNum, remainder, sum = 0;

    cout << "Enter a number: ";
    cin >> num;

    originalNum = num;

    // Calculate sum of factorials of digits
    while (num != 0) {
        remainder = num % 10;
        sum += factorial(remainder);
        num /= 10;
    }

    // Check strong number
    if (sum == originalNum)
        cout << originalNum << " is a Strong number.";
    else
        cout << originalNum << " is not a Strong number.";

    return 0;
}
