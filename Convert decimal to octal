#include <iostream>
using namespace std;

int main() {
    int decimal, octal = 0, place = 1, remainder;

    cout << "Enter a decimal number: ";
    cin >> decimal;

    while(decimal > 0) {
        remainder = decimal % 8;          // divide by 8
        octal = octal + remainder * place;
        place = place * 10;
        decimal = decimal / 8;
    }
    cout << "Octal value = " << octal;
    return 0;
}
