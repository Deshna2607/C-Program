#include <iostream>
using namespace std;

int main() {
    int num, digit, target, count = 0;

    cout << "Enter a number: ";
    cin >> num;

    cout << "Enter digit to find: ";
    cin >> target;

    while(num > 0) {
        digit = num % 10;   // extract last digit

        if(digit == target) {
            count++;
        }

        num = num / 10;     // remove last digit
    }

    cout << "Frequency of " << target << " = " << count;

    return 0;
}
