#include <iostream>
using namespace std;

int main() {
    int num, digit, largest = 0;

    cout << "Enter a number: ";
    cin >> num;

    while(num > 0) {
        digit = num % 10;   // extract last digit

        if(digit > largest) {
            largest = digit;
        }

        num = num / 10;     // remove last digit
    }

    cout << "Largest digit = " << largest;

    return 0;
}
